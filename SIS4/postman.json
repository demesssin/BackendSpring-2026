{
  "info": {
    "name": "Event Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Event",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"KBTU Tech Conference 2026\",\n  \"description\": \"Annual technology conference\",\n  \"organizerEmail\": \"organizer@kbtu.kz\",\n  \"location\": \"Almaty, Kazakhstan\",\n  \"eventDate\": \"2026-09-15T10:00:00\",\n  \"ticketPrice\": 5000,\n  \"minAge\": 16\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/events",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "events"]
        }
      }
    },
    {
